# =============================================================
# INDOR — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env
# =============================================================

# ----- App -----
NODE_ENV=development
PORT=3001

# ----- Database (PostgreSQL 15) -----
DB_USER=indor
DB_PASSWORD=your_db_password_here
DB_NAME=indor_db
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- Auth (JWT) -----
JWT_SECRET=replace_with_random_64char_hex
JWT_REFRESH_SECRET=replace_with_different_random_64char_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- OAuth (Google) -----
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ----- Stripe (test mode) -----
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# ----- AWS S3 / MinIO (local dev uses MinIO) -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=indor-documents
AWS_S3_ENDPOINT=http://localhost:9000  # Remove in production (AWS endpoint)

# ----- MinIO (local dev only) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ----- Google Maps -----
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ----- Email (SendGrid) -----
SENDGRID_API_KEY=SG.replace_with_your_sendgrid_key
EMAIL_FROM=noreply@indor.com

# ----- SMS (Twilio) -----
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ----- Synchrony Financial (Phase 4+ only — stub for MVP) -----
SYNCHRONY_API_KEY=replace_when_available
SYNCHRONY_API_URL=https://api.synchrony.com  # Sandbox URL when provided

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_test_key
